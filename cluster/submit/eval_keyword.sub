# Replace placeholders before submitting:
# <user>, <home_dir>, <project_dir>, <log_dir>, <hf_home>, <docker_image>

universe = docker
docker_image = <docker_image>

executable = <project_dir>/cluster/scripts/run.sh
arguments = eval_keyword
initialdir = <home_dir>

should_transfer_files = NO
getenv = True
environment = "LSV_USER=<user> PROJECT_DIR=<project_dir> CONFIG_PATH=cluster/config.cluster.toml BASE_ARTIFACT_DIR=<project_dir>/artifacts/rag RUN_ID=eval-keyword-$(Cluster)-$(Process) HF_HOME=<hf_home>"

log = <log_dir>/eval_keyword.$(Cluster).$(Process).log
output = <log_dir>/eval_keyword.$(Cluster).$(Process).out
error = <log_dir>/eval_keyword.$(Cluster).$(Process).err

request_cpus = 2
request_memory = 8GB
request_disk = 20GB
requirements = (TARGET.UidDomain == "coli.uni-saarland.de")

queue
